---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// Hol die Events aus der Content Collection
const allEvents = await getCollection('events');
const homepageSettings = await getEntry('settings', 'homepage');
const { hero, highlights, newsletter } = homepageSettings.data;

// Sortiere und filtere die Events
const upcomingEvents = allEvents
  .filter(event => !event.data.isPast)
  .sort((a, b) => a.data.title.localeCompare(b.data.title)); // Vereinfachte Sortierung, da Datum ein String ist

const pastEvents = allEvents
  .filter(event => event.data.isPast)
  .sort((a, b) => b.data.title.localeCompare(a.data.title));
---

<Layout>
<div class="bg-gray-50 min-h-screen">
  <!-- Hero Section -->
  <div class="relative h-[600px] overflow-hidden">
    <img
      src={hero.image}
      alt="Dorf Büttel"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/50 to-black/80"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 pt-16">
      <span class="text-green-400 font-semibold tracking-wider uppercase mb-4 text-sm md:text-base">
        Bürgerverein Büttel e.V.
      </span>
      <h1 class="text-5xl md:text-7xl font-bold mb-6 text-white drop-shadow-lg">
        {hero.title}
      </h1>
      <p class="text-xl md:text-2xl mb-10 max-w-2xl mx-auto text-gray-200 font-light">
        {hero.subtitle}
      </p>
      <a
        href="#events"
        class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-full transition-all hover:scale-105 font-medium shadow-lg hover:shadow-green-600/25"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
        </svg>
        {hero.ctaText}
      </a>
    </div>
  </div>

  <!-- Main Events Section -->
  <div id="events" class="max-w-7xl mx-auto mt-0 px-4 sm:px-6 lg:px-8 py-20 -mt-20 relative z-10">
    <div class="flex items-center gap-4 mb-10 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
      <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-green-700">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
        </svg>
      </div>
      <div>
        <h2 class="text-3xl font-bold text-gray-900">Demnächst in Büttel</h2>
        <p class="text-gray-500 mt-1">Verpassen Sie keine unserer anstehenden Aktivitäten.</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {upcomingEvents.map((event) => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group flex flex-col h-full">
          <div class="h-48 overflow-hidden relative">
            <img
              src={event.data.image}
              alt={event.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            {event.data.isPast && (
              <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white px-3 py-1 rounded-full text-sm font-medium">
                Vergangen
              </div>
            )}
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-bold text-xl mb-4 text-gray-900 line-clamp-2">{event.data.title}</h3>
            <div class="space-y-3 mb-6 flex-1">
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
                  </svg>
                </div>
                <span class="font-medium">{event.data.date}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <span>{event.data.time}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <span class="line-clamp-1">{event.data.location}</span>
              </div>
            </div>
            <p class="text-gray-600 line-clamp-3 mb-6">{event.data.description}</p>
            <a
              href={`/veranstaltung/${event.slug}`}
              class="w-full py-3 px-4 bg-gray-50 hover:bg-green-50 text-green-700 font-medium rounded-lg transition-colors mt-auto border border-gray-100 hover:border-green-200 block text-center"
            >
              Details ansehen
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Highlights Section -->
  <div class="bg-white py-20 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Das macht uns aus</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Büttel ist mehr als nur ein Wohnort. Wir sind eine aktive Gemeinschaft, die Traditionen pflegt und Neues schafft.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        {highlights.map((item) => (
          <div class="text-center group">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gray-50 group-hover:bg-green-50 rounded-2xl mb-6 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-green-700" set:html={item.icon} />
            </div>
            <h3 class="text-xl font-bold mb-3 text-gray-900">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Past Events -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-center gap-4 mb-10">
      <div class="w-2 h-8 bg-gray-300 rounded-full"></div>
      <h2 class="text-3xl font-bold text-gray-900">Rückblick: Letzte Veranstaltungen</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:w-2/3">
      {pastEvents.map((event) => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group flex flex-col h-full">
          <div class="h-48 overflow-hidden relative">
            <img
              src={event.data.image}
              alt={event.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            {event.data.isPast && (
              <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white px-3 py-1 rounded-full text-sm font-medium">
                Vergangen
              </div>
            )}
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-bold text-xl mb-4 text-gray-900 line-clamp-2">{event.data.title}</h3>
            <div class="space-y-3 mb-6 flex-1">
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
                  </svg>
                </div>
                <span class="font-medium">{event.data.date}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <span>{event.data.time}</span>
              </div>
              <div class="flex items-center gap-3 text-gray-600">
                <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-700">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <span class="line-clamp-1">{event.data.location}</span>
              </div>
            </div>
            <p class="text-gray-600 line-clamp-3 mb-6">{event.data.description}</p>
            <a
              href={`/veranstaltung/${event.slug}`}
              class="w-full py-3 px-4 bg-gray-50 hover:bg-green-50 text-green-700 font-medium rounded-lg transition-colors mt-auto border border-gray-100 hover:border-green-200 block text-center"
            >
              Details ansehen
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Newsletter / CTA -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="bg-gray-900 rounded-3xl p-10 md:p-16 text-center text-white relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
        <img
           src={newsletter.image}
           alt="Background"
           class="w-full h-full object-cover"
        />
      </div>
      <div class="relative z-10">
        <h3 class="text-3xl md:text-4xl font-bold mb-6">
          {newsletter.title}
        </h3>
        <p class="mb-10 max-w-2xl mx-auto text-gray-300 text-lg">
          {newsletter.description}
        </p>
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
          <input 
            type="email" 
            placeholder="Deine E-Mail Adresse" 
            required
            class="flex-1 px-6 py-4 rounded-xl text-gray-900 outline-none focus:ring-2 focus:ring-green-500"
          />
          <button type="submit" class="bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-xl transition-colors font-medium whitespace-nowrap">
            Anmelden
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
</Layout>

<script>
  // Verhindert das Neuladen der Seite beim Absenden des Newsletters
  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Hier kannst du später deine Logik zum Speichern der E-Mail einbauen
    alert('Vielen Dank für die Anmeldung!');
    form.reset();
  });
</script>
